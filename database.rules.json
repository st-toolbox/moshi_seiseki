{
  "rules": {
    ".read": false,
    ".write": false,

    "teachers": {
      ".read": "auth != null",
      ".write": "root.child('teachers').child(auth.uid).exists()"
    },

    "pending_teachers": {
      ".read": "root.child('teachers').child(auth.uid).exists()",
      ".write": "root.child('teachers').child(auth.uid).exists()",
      "$emailKey": {
        ".read": "auth != null"
      }
    },

    "exams": {
      ".read": "auth != null",
      ".write": "root.child('teachers').child(auth.uid).exists()"
    },

    "students": {
      ".read": "auth != null",
      ".write": "root.child('teachers').child(auth.uid).exists()"
    },

    "responses": {
      ".read": "root.child('teachers').child(auth.uid).exists()",
      "$examId": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && (auth.uid === $uid || root.child('teachers').child(auth.uid).exists())"
        }
      }
    }
  }
}
